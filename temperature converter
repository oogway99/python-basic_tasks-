# temperature conversion using if else
x = float (input(" enter the value =") )
y = str(input("which conversion do you want C or F = "))
if y == str("C")or str ("c"):
    print ("fahrenheit to celsius", ((x-32)*(5/9)))
elif y == str("F") or str("f"):
    print ("celsius to fahrenheit", (x*(9/5)+32 ))
else:
    print ("not the required scale")
